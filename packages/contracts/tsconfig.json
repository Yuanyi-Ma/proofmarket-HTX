{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "mocha"],
    "skipLibCheck": true
  },
  "include": ["hardhat.config.ts", "test/**/*.ts", "scripts/**/*.ts"],
  "ts-node": {
    "moduleTypes": {
      "hardhat.config.ts": "cjs",
      "test/**/*.ts": "cjs"
    }
  }
}
