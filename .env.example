# Mode: fixture (local demo, fake values, labeled) | real (Injective/Sepolia + restricted signer + Codex/Claude)
PROOFMARKET_MODE=fixture
# Real-mode network: injective-testnet (recommended for this branch) | sepolia
PROOFMARKET_NETWORK=injective-testnet
# Optional explicit artifact path. When unset, real mode tries deployments/injective.json then deployments/sepolia.json.
PROOFMARKET_DEPLOYMENT_PATH=
INJECTIVE_EVM_RPC_URL=https://testnet.evm.archival.chain.virtual.json-rpc.injective.network/
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Local test key that deploys contracts and pays deploy gas. NEVER a real-money key.
DEPLOYER_PRIVATE_KEY=
# Local test key for the demo Provider identity (submits deliverable hash on-chain).
# Also the ERC-8004 reputation rater: posts giveFeedback after settle/challenge
# (must NOT be the agent NFT owner, which is the deployer).
PROVIDER_SIGNER_PRIVATE_KEY=
# Address of the provider signer key above.
PROVIDER_SIGNER_ADDRESS=
# Optional per-Provider keys for non-recommended demo paths. These are needed
# when a real chain job is funded for that Provider and it must submit/defend.
PROVIDER_SHALLOW_SEARCH_PROVIDER_PRIVATE_KEY=
PROVIDER_GENERAL_WEB_SUMMARY_PRIVATE_KEY=
# Local test key for the challenge resolver (signs ChallengeManager.resolve directly,
# not via the restricted signer). Must match the resolver address baked into the deployment.
RESOLVER_PRIVATE_KEY=
# Address of the resolver key above.
RESOLVER_ADDRESS=
# Restricted signer address (escrow client + evaluator).
POLICY_SIGNER_WALLET_ADDRESS=
# Local test key for the policy signer. The signer checks policy boundaries
# before signing and must match POLICY_SIGNER_WALLET_ADDRESS.
POLICY_SIGNER_PRIVATE_KEY=
# Deterministic Provider/Judge service.
SERVICES_URL=http://localhost:4010
SERVICES_PORT=4010
# Research plan source: codex (default) | claude | preset.
PROOFMARKET_PLAN_SOURCE=codex
CODEX_BIN=codex
PROOFMARKET_CODEX_SERVICE_TIER=fast
PROOFMARKET_CODEX_TIMEOUT_MS=240000
# Claude Code binary for the optional fallback research agent.
CLAUDE_BIN=claude
